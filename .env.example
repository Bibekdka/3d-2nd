# Environment Configuration Template
# Copy this file to .env and fill in your values

# ===== AI Server Configuration =====
# URL where local AI/Ollama server is running
LOCAL_AI_URL=http://127.0.0.1:8000
LOCAL_AI_TIMEOUT=60
LOCAL_AI_HEALTH_CHECK_TIMEOUT=2

# ===== Database Configuration =====
# Google Sheets configuration (via Streamlit secrets, but template for reference)
# These are typically stored in .streamlit/secrets.toml in development
# In production, use Streamlit Cloud's secret management
SHEET_NAME=printer_brain
WORKSHEET_NAME=history

# ===== Application Settings =====
# Environment: development, staging, or production
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ===== Logging =====
# Log file location
LOG_FILE=app.log
ENABLE_FILE_LOGGING=true

# ===== API & Scraper Configuration =====
# Browser timeout for scraping (in milliseconds)
SCRAPER_TIMEOUT=45000
# Max requests per minute for GROK API
GROK_RATE_LIMIT=60
# Request retry count
REQUEST_MAX_RETRIES=3
REQUEST_RETRY_DELAY=2

# ===== Performance =====
# Enable caching
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600

# ===== Security =====
# Enable CORS for API
ENABLE_CORS=true
# Allowed origins (comma-separated for production)
ALLOWED_ORIGINS=*

# ===== Google Sheets (Reference) =====
# Store sensitive credentials in .streamlit/secrets.toml, not here
# Example secrets.toml structure:
# [gsheets]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "your-key-id"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "your-service-account@example.iam.gserviceaccount.com"
# client_id = "your-client-id"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
